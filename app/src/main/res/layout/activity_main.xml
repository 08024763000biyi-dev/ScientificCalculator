<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="8dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp" android:layout_marginTop="60dp">
        <Button android:id="@+id/btnMatrixMode" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Matrix" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btnStatsMode" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Stats" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
    </LinearLayout>

    <TextView android:id="@+id/tvExpression" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="end" android:textSize="18sp" android:textColor="#888888" android:paddingEnd="8dp"/>
    <TextView android:id="@+id/tvDisplay" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="end" android:textSize="40sp" android:text="0" android:textColor="@android:color/white" android:paddingEnd="8dp" android:layout_marginBottom="16dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/btn2nd" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="2nd" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btnDegRad" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Deg" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btnSin" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="sin" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btnCos" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="cos" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btnTan" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="tan" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/btnSinh" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="sinh" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btnCosh" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="cosh" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btnTanh" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="tanh" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/btnLog" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="lg" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btnLn" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="ln" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btnLeftBracket" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="(" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btnRightBracket" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text=")" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/btnSqrt" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="√" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btnClear" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="AC" android:textColor="#F39C12" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btnDel" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="DEL" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btnPercent" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="%" android:textColor="#F39C12" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btnDiv" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="÷" android:textColor="#F39C12" android:backgroundTint="#333333"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/btnFact" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="x!" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btn7" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="7" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btn8" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="8" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btn9" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="9" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btnMul" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="×" android:textColor="#F39C12" android:backgroundTint="#333333"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/btnInv" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="1/x" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btn4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="4" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btn5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="5" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btn6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="6" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btnSub" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="-" android:textColor="#F39C12" android:backgroundTint="#333333"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/btnPi" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="π" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btn1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="1" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btn2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="2" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btn3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="3" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btnAdd" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="+" android:textColor="#F39C12" android:backgroundTint="#333333"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/btnE" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="e" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btn0" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="0" android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btnDot" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="." android:textColor="@android:color/white" android:backgroundTint="#333333"/>
        <Button android:id="@+id/btnEqual" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="=" android:textColor="@android:color/white" android:backgroundTint="#F39C12"/>
    </LinearLayout>

</LinearLayout>